{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawEgg",
  "version": "0.1.0",
  "identifier": "com.clawegg.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ClawEgg - OpenClaw Installer",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "OpenClaw One-Click Installer",
    "longDescription": "A cross-platform installer for OpenClaw AI Agent platform",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
